# EditorConfig — Phenotype org canonical
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = tab
indent_size = 2
trim_trailing_whitespace = true

[*.{md,yml,yaml,json}]
indent_style = space

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false  # trailing spaces = line break in Markdown
